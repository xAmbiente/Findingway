{
	"name": "findingway",
	"version": "2.0.0",
	"description": "FFXIV Party Finder Discord bot",
	"author": {
		"name": "xAmbiente",
		"email": "theambiente@icloud.com"
	},
	"contributors": [
		{
			"name": "favna",
			"email": "support@favware.tech"
		}
	],
	"license": "Apache-2.0",
	"module": "dist/findingway.mjs",
	"private": true,
	"type": "module",
	"imports": {
		"#lib/*": "./dist/lib/*.mjs",
		"#root/*": "./dist/*.mjs",
		"#utils/*": "./dist/lib/util/*.mjs",
		"#lib/env": "./dist/lib/env/index.mjs"
	},
	"scripts": {
		"start": "node --preserve-symlinks --enable-source-maps dist/findingway.mjs",
		"lint": "eslint --fix",
		"format": "prettier --write .",
		"prisma:generate": "prisma generate",
		"build": "tsdown",
		"watch": "tsdown --watch",
		"clean": "rimraf dist/",
		"typecheck": "tsc -b src",
		"dev": "tsdown --watch --onSuccess \"yarn start\""
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@sapphire/decorators": "^6.2.0",
		"@sapphire/discord.js-utilities": "^7.3.3",
		"@sapphire/fetch": "^3.0.5",
		"@sapphire/framework": "^5.5.0",
		"@sapphire/plugin-i18next": "^8.0.0",
		"@sapphire/plugin-logger": "^4.1.0",
		"@sapphire/plugin-scheduled-tasks": "^10.0.4",
		"@sapphire/utilities": "^3.18.2",
		"@skyra/env-utilities": "^2.0.1",
		"@skyra/start-banner": "^2.0.2",
		"bufferutil": "^4.1.0",
		"bullmq": "^5.79.1",
		"colorette": "^2.0.20",
		"discord.js": "^14.26.4",
		"figlet": "^1.11.0",
		"gradient-string": "^3.0.0",
		"i18next": "^26.3.3",
		"playwright": "^1.61.1",
		"utf-8-validate": "^6.0.6",
		"ws": "^8.21.0"
	},
	"devDependencies": {
		"@favware/discord-application-emojis-manager": "^1.1.1",
		"@playwright/mcp": "^0.0.76",
		"@sapphire/prettier-config": "^2.0.0",
		"@sapphire/ts-config": "^5.0.3",
		"@swc/core": "^1.15.43",
		"@types/figlet": "^1.7.0",
		"@types/gradient-string": "^1.1.6",
		"@types/node": "^24.13.2",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"eslint": "^10.6.0",
		"eslint-config-neon": "^0.5.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.0",
		"prettier-plugin-prisma": "^5.0.0",
		"prisma": "^7.8.0",
		"rimraf": "^6.1.3",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3"
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write",
		"*.{mjs,js,ts}": "eslint --fix"
	},
	"packageManager": "yarn@4.17.0"
}
